# Build-Context ist der Repo-Root. Nur src/ wird ins Image kopiert –
# alles andere hier ausschliessen (kleinerer Context, schnellerer Kaniko-Build).

# Virtual environment / Python caches
.venv/
venv/
**/__pycache__/
*.pyc
*.pyo
**/.pytest_cache/

# Datenbank-/Daten-Dateien – nie ins Image
**/*.db
**/*.sqlite
**/*.sqlite3

# Version control / Doku / CI
.git/
.gitignore
.gitattributes
*.md
azure-pipelines.yml

# Kubernetes-Manifeste + interne Referenz-Repos (nicht im Image)
k8s/
inspo/
DP.helm-generic/
GAI.ai-prod-label-studio/
design bib/
*.zip

# In src/, aber nicht im Image benoetigt
src/tests/
src/docker-compose.yml
src/.dockerignore

# Sonstiges
.env
.DS_Store
Thumbs.db
